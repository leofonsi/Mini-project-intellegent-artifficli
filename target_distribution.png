    "from sklearn.decomposition import PCA\n",
    "from sklearn.cluster import KMeans\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "Xp = pre.fit_transform(X)\n",
    "Xp = Xp.toarray() if hasattr(Xp, 'toarray') else Xp\n",
    "X2 = PCA(n_components=2, random_state=42).fit_transform(Xp)\n",
    "cl = KMeans(n_clusters=2, n_init=10, random_state=42).fit_predict(Xp)\n",
    "fig, ax = plt.subplots(1, 2, figsize=(12, 5))\n",
    "ax[0].scatter(X2[:,0], X2[:,1], c=y)\n",
    "ax[0].set_title('PCA par cible')\n",
    "ax[1].scatter(X2[:,0], X2[:,1], c=cl)\n",
    "ax[1].set_title('PCA par clusters')\n",
    "plt.show()"
   ]
